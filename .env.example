# ════════════════════════════════════════════════════════
# CHAOS CREW v5 – Environment
# Kopiere diese Datei nach .env und passe Werte an
# ════════════════════════════════════════════════════════

# Streamerbot WebSocket (Windows-PC)
SB_HOST=192.168.178.39
SB_PORT=9090

# PostgreSQL
PG_DB=chaoscrew
PG_USER=chaoscrew
PG_PASSWORD=changeme_sichere_passwort

# Redis UI
REDIS_UI_USER=chaos
REDIS_UI_PASSWORD=changeme

# Domain (leer = nur HTTP Port 80)
DOMAIN=

# Caddy Config (Caddyfile = HTTP, Caddyfile.ssl = HTTPS)
CADDY_CONFIG=Caddyfile

# SSH Deployment (LXC Server)
SSH_HOST=192.168.178.34
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=changeme
SSH_DEPLOY_PATH=/opt/streamertools

# Chat-KI (optional). Verschluesselt die pro Team hinterlegten API-Keys.
# Ohne diesen Wert laesst sich kein KI-Key speichern. Aendern = alle Keys unlesbar.
# Erzeugen: openssl rand -base64 32
AI_KEY_SECRET=
