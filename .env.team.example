# ════════════════════════════════════════════════════════
# Team-Giveaway (team.raumdock.org) – Environment  (LXC 103)
# Copy to .env on the server. Secrets NOT committed.
# ════════════════════════════════════════════════════════

# Public domain (drives Caddyfile.team {$DOMAIN} + cert)
DOMAIN=team.raumdock.org

# Team stack uses the TLS/DNS-01 Caddyfile
CADDY_CONFIG=Caddyfile.team

# Cloudflare API token for DNS-01 ACME — copied from /opt/RDOC-Suite/.env
CF_API_TOKEN=

# PostgreSQL (own volume, isolated from RDOC-Suite)
PG_DB=chaoscrew
PG_USER=chaoscrew
PG_PASSWORD=

# Redis UI (loopback only)
REDIS_UI_USER=chaos
REDIS_UI_PASSWORD=

# ── Login / Benutzerverwaltung (admin service) ──
# Stable secret for signed session cookies (openssl rand -hex 32).
# If unset, sessions drop on every admin restart.
SESSION_SECRET=
# Bootstrap superadmin (created only when the admin_users table is empty).
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASS=
# Twitch-Logins mit Plattform-Adminrechten (Superadmin): Redis Commander,
# /health, Benutzerverwaltung. Komma-getrennt, wird bei jedem Start gesetzt.
PLATFORM_ADMINS=justcallmedeimos
# Cookies require HTTPS in prod; set false only for local HTTP dev.
COOKIE_SECURE=true

# Streamerbot ingest — Phase 1 inverts this (bots connect IN). For the
# initial pipeline smoke-test the old outbound bridge target is unused/unreachable.
SB_HOST=127.0.0.1
SB_PORT=9090
